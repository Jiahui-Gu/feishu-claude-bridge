# Feishu App credentials (required)
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# Claude Code working directory (defaults to current directory)
# CLAUDE_WORK_DIR=/path/to/your/project

# Max concurrent Claude tasks (default: 3)
# CLAUDE_MAX_CONCURRENT=3

# Timeout in ms (default: 600000 = 10 minutes)
# CLAUDE_TIMEOUT=600000

# Max turns per Claude invocation (default: 25)
# CLAUDE_MAX_TURNS=25

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
